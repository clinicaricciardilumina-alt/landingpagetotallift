{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/chat.ts": { "maxDuration": 30 },
    "api/send-email.ts": { "maxDuration": 15 },
    "api/send-broadcast.ts": { "maxDuration": 60 },
    "api/run-scheduled.ts": { "maxDuration": 60 },
    "api/enroll-lead.ts": { "maxDuration": 15 },
    "api/google-reviews-refresh.ts": { "maxDuration": 15 }
  },
  "crons": [
    {
      "path": "/api/run-scheduled",
      "schedule": "0 9 * * *"
    }
  ]
}
